# Serper.dev API key - get one free at https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# OpenRouter API key - get one free at https://openrouter.ai
# This app uses free-tier models only (e.g. openai/gpt-oss-120b:free)
# No payment required - sign up and generate a key from the API Keys page
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Port for the Express backend (optional, defaults to 3001 if not set)
PORT=3001

